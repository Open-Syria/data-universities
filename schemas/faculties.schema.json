{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensyria.org/schemas/data-universities/faculties.schema.json",
  "title": "OpenSyria University Faculties",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "universityId",
      "name",
      "aliases",
      "facultyType",
      "operationalStatus",
      "website",
      "sourceIds",
      "sourceStatus"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^sy-[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "universityId": {
        "type": "string",
        "pattern": "^sy-[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "name": {
        "$ref": "#/$defs/localizedText"
      },
      "aliases": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/alias"
        }
      },
      "facultyType": {
        "type": "string",
        "enum": ["faculty", "college", "institute", "school", "center", "department", "other"]
      },
      "operationalStatus": {
        "type": "string",
        "enum": ["operating", "planned", "closed", "unknown"]
      },
      "website": {
        "type": ["string", "null"],
        "format": "uri"
      },
      "sourceIds": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "minItems": 1
      },
      "sourceStatus": {
        "type": "string",
        "enum": ["pending_release", "seed", "released", "deprecated"]
      },
      "notes": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "localizedText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["en"],
      "properties": {
        "en": {
          "type": "string",
          "minLength": 1
        },
        "ar": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "alias": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value"],
      "properties": {
        "value": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "enum": ["ar", "en", "und"]
        },
        "type": {
          "type": "string",
          "enum": ["alias", "formal", "transliteration", "historical", "alternate_spelling"]
        }
      }
    }
  }
}
